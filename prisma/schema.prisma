// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id
  name          String
  email         String
  password      String?
  emailVerified Boolean @default(false)
  image         String?

  role UserRole @default(USER)

  hasCompletedOnboarding Boolean   @default(false)
  skippedOnboardingAt    DateTime?

  profileAvatarFileAssetId String?
  profileAvatarFileAsset   FileAsset? @relation("UserProfileAvatarAsset", fields: [profileAvatarFileAssetId], references: [id], onDelete: SetNull)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  sessions   Session[]
  accounts   Account[]
  fileAssets FileAsset[] @relation("UploadedByUser")

  investorProfile      InvestorProfile?
  auditLogs            AuditLog[]            @relation("ActorAuditLogs")
  cryptoFundingIntents CryptoFundingIntent[]

  @@unique([email])
  @@index([profileAvatarFileAssetId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordResetAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

/// Central file registry for all uploaded files.
/// Store only metadata here; actual binary lives in S3, UploadThing, Cloudinary, etc.
model FileAsset {
  id String @id @default(cuid())

  fileName     String
  originalName String?

  mimeType       String?
  extension      String?
  sizeBytes      BigInt?
  checksumSha256 String?

  storageKey      String              @unique
  storageBucket   String?
  storageProvider FileStorageProvider
  url             String?

  type       FileAssetType       @default(OTHER)
  visibility FileAssetVisibility @default(PRIVATE)

  uploadedById String?
  uploadedBy   User?   @relation("UploadedByUser", fields: [uploadedById], references: [id], onDelete: SetNull)

  investmentIcons Investment[] @relation("InvestmentIconAsset")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usersAsProfileAvatar     User[]            @relation("UserProfileAvatarAsset")
  investorProfilesAsAvatar InvestorProfile[] @relation("InvestorAvatar")

  siteConfigurationDefaultOgImages SiteConfiguration[] @relation("SiteConfigurationDefaultOgImage")
  siteLogo                         SiteConfiguration?  @relation("SiteConfigurationLogo")
  investmentPlanSeoImages          InvestmentPlan[]    @relation("InvestmentPlanSeoImage")

  kycDocuments KycDocument[]
  testimonies  Testimony[]
  management   Management[]

  @@index([uploadedById])
  @@index([type])
  @@index([visibility])
  @@map("file_asset")
}

/// End-user / investor profile
model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber  String?
  dateOfBirth  DateTime?
  age          Int       @default(18)
  country      String?
  state        String?
  city         String?
  addressLine1 String?
  addressLine2 String?

  kycStatus KycStatus @default(NOT_STARTED)

  avatarFileId String?
  avatarFile   FileAsset? @relation("InvestorAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)

  investmentAccounts InvestmentAccount[]

  investmentOrders InvestmentOrder[]

  kycDocuments KycDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kycStatus])
  @@index([avatarFileId])
  @@map("investor_profile")
}

/// The customer’s actual investment account
model InvestmentAccount {
  id                String @id @default(cuid())
  investorProfileId String
  investmentPlanId  String

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  investmentPlan  InvestmentPlan  @relation(fields: [investmentPlanId], references: [id], onDelete: Restrict)

  investmentOrders InvestmentOrder[]
  status           AccountStatus     @default(PENDING)
  balance          Decimal           @default(0) @db.Decimal(18, 2)
  openedAt         DateTime?
  closedAt         DateTime?

  currency String @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorProfileId])
  @@index([investmentPlanId])
  @@index([status])
  @@map("investment_account")
}

model Investment {
  id   String @id @default(cuid())
  name String
  slug String @unique

  description String?

  type   InvestmentType          @default(CRYPTO)
  period InvestmentPeriod        @default(LONG_TERM)
  status InvestmentCatalogStatus @default(ACTIVE)

  iconFileAssetId String?
  iconFileAsset   FileAsset? @relation("InvestmentIconAsset", fields: [iconFileAssetId], references: [id], onDelete: SetNull)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  investmentPlans InvestmentPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([period])
  @@index([status])
  @@index([isActive])
  @@index([sortOrder])
  @@index([iconFileAssetId])
  @@map("investment")
}

model InvestmentPlan {
  id           String @id @default(cuid())
  investmentId String

  name String
  slug String @unique

  description String?

  seoTitle       String?
  seoDescription String?
  seoImageFileId String?
  seoImageFile   FileAsset? @relation("InvestmentPlanSeoImage", fields: [seoImageFileId], references: [id], onDelete: SetNull)

  sortOrder Int              @default(0)
  period    InvestmentPeriod @default(LONG_TERM)

  currency String  @default("USD")
  isActive Boolean @default(true)

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  investmentAccounts InvestmentAccount[]
  investmentOrders   InvestmentOrder[]
  tiers              InvestmentPlanTier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investmentId])
  @@index([period])
  @@index([isActive])
  @@map("investment_plan")
}

model InvestmentPlanTier {
  id               String @id @default(cuid())
  investmentPlanId String

  level InvestmentTierLevel @default(CORE)

  minAmount Decimal @db.Decimal(18, 2)
  maxAmount Decimal @db.Decimal(18, 2)

  roiPercent Decimal @db.Decimal(5, 2)

  isActive Boolean @default(true)

  investmentPlan InvestmentPlan @relation(fields: [investmentPlanId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  investmentOrders InvestmentOrder[]

  @@index([investmentPlanId])
  @@index([level])
  @@map("investment_plan_tier")
}

model InvestmentOrder {
  id                   String  @id @default(cuid())
  investorProfileId    String
  investmentPlanId     String
  investmentAccountId  String?
  investmentPlanTierId String

  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  status InvestmentOrderStatus @default(PENDING_PAYMENT)

  paymentReference String?
  paidAt           DateTime?
  confirmedAt      DateTime?
  cancelledAt      DateTime?

  cancellationReason String?
  adminNotes         String?

  investmentPlanTier InvestmentPlanTier @relation(fields: [investmentPlanTierId], references: [id])
  investorProfile    InvestorProfile    @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  investmentPlan     InvestmentPlan     @relation(fields: [investmentPlanId], references: [id], onDelete: Restrict)
  investmentAccount  InvestmentAccount? @relation(fields: [investmentAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorProfileId])
  @@index([investmentPlanId])
  @@index([investmentAccountId])
  @@index([status])
  @@index([paidAt])
  @@index([confirmedAt])
  @@index([cancelledAt])
  @@map("investment_order")
}

/// KYC document records point to FileAsset
model KycDocument {
  id                String @id @default(cuid())
  investorProfileId String
  fileAssetId       String

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  fileAsset       FileAsset       @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  documentType String
  status       KycStatus @default(PENDING_REVIEW)
  reviewedById String?
  reviewedAt   DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorProfileId])
  @@index([fileAssetId])
  @@index([status])
  @@map("kyc_document")
}

/// Internal audit log for admin/moderator/sensitive actions
model AuditLog {
  id          String  @id @default(cuid())
  actorUserId String?
  actorUser   User?   @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  action      String
  entityType  String
  entityId    String?
  description String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

/// testimonials and reviews
model Testimony {
  id          String          @id @default(cuid())
  fullName    String
  roleOrTitle String?         @default("CLIENT")
  message     String
  rating      Int?
  isFeatured  Boolean         @default(false)
  status      TestimonyStatus @default(DRAFT)

  avatarFileId String?
  avatarFile   FileAsset? @relation(fields: [avatarFileId], references: [id], onDelete: SetNull)

  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([avatarFileId])
  @@map("testimony")
}

/// managements
model Management {
  id String @id @default(cuid())

  name  String
  title String?
  role  String?

  email String?
  phone String?
  bio   String?

  photoFileId String?
  photoFile   FileAsset? @relation(fields: [photoFileId], references: [id], onDelete: SetNull)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  @@index([photoFileId])
  @@map("management")
}

/// Crypto funding models
model PlatformWallet {
  id        String        @id @default(cuid())
  label     String
  asset     CryptoAsset
  network   CryptoNetwork
  address   String
  isActive  Boolean       @default(true)
  isDefault Boolean       @default(false)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  fundingIntents CryptoFundingIntent[]

  @@unique([network, address])
  @@index([asset, network, isActive])
  @@index([isDefault, isActive])
}

model CryptoFundingIntent {
  id       String                @id @default(cuid())
  userId   String
  provider CryptoFundingProvider
  asset    CryptoAsset
  network  CryptoNetwork

  fiatCurrency String  @default("USD")
  fiatAmount   Decimal @db.Decimal(18, 2)

  expectedCryptoAmount Decimal? @db.Decimal(36, 18)
  receivedCryptoAmount Decimal? @db.Decimal(36, 18)

  status CryptoFundingIntentStatus @default(PENDING)

  platformWalletId         String?
  destinationWalletAddress String
  destinationWalletLabel   String?

  providerSessionId  String?
  providerExternalId String?
  providerReference  String?

  partnerCustomerId String?
  redirectUrl       String?

  expiresAt  DateTime?
  fundedAt   DateTime?
  failedAt   DateTime?
  canceledAt DateTime?

  failureCode    String?
  failureMessage String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformWallet PlatformWallet? @relation(fields: [platformWalletId], references: [id], onDelete: SetNull)

  bitpayInvoicePayment BitPayInvoicePayment?
  webhookEvents        CryptoWebhookEvent[]

  @@index([userId, status])
  @@index([provider, status])
  @@index([asset, network])
  @@index([providerSessionId])
  @@index([providerExternalId])
  @@index([createdAt])
}

model BitPayInvoicePayment {
  id              String @id @default(cuid())
  fundingIntentId String @unique

  bitpayInvoiceId String              @unique
  bitpayOrderId   String?
  bitpayToken     String?
  status          BitPayInvoiceStatus @default(NEW)

  price    Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  cryptoAsset   CryptoAsset?
  cryptoNetwork CryptoNetwork?
  amountPaid    Decimal?       @db.Decimal(36, 18)
  amountDue     Decimal?       @db.Decimal(36, 18)
  exchangeRate  Decimal?       @db.Decimal(36, 18)

  invoiceUrl String?
  posData    String?

  paidAt      DateTime?
  confirmedAt DateTime?
  completedAt DateTime?
  expiredAt   DateTime?
  invalidAt   DateTime?

  rawInvoiceSnapshot Json?
  rawStatusPayload   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundingIntent CryptoFundingIntent @relation(fields: [fundingIntentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model CryptoWebhookEvent {
  id               String                        @id @default(cuid())
  source           CryptoWebhookSource
  eventType        String
  processingStatus CryptoWebhookProcessingStatus @default(RECEIVED)

  fundingIntentId  String?
  providerEventId  String?
  providerObjectId String?

  idempotencyKey String? @unique
  signature      String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  failedAt    DateTime?

  errorMessage String?
  payload      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundingIntent CryptoFundingIntent? @relation(fields: [fundingIntentId], references: [id], onDelete: SetNull)

  @@index([source, eventType])
  @@index([processingStatus])
  @@index([providerEventId])
  @@index([providerObjectId])
  @@index([receivedAt])
}

/// site configuration
model SiteConfiguration {
  id String @id @default("default")

  siteName     String
  supportEmail String?
  supportPhone String?

  siteDescription String?
  siteTagline     String?

  siteLogoFileAssetId String?    @unique
  siteLogoFileAsset   FileAsset? @relation("SiteConfigurationLogo", fields: [siteLogoFileAssetId], references: [id], onDelete: SetNull)

  seoTitle       String?
  seoDescription String?

  locale   String?  @default("en_US")
  keywords String[] @default([])

  defaultTwitterHandle String?
  facebookUrl          String?
  instagramUrl         String?

  defaultOgImageFileAssetId String?
  defaultOgImageFileAsset   FileAsset? @relation("SiteConfigurationDefaultOgImage", fields: [defaultOgImageFileAssetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([defaultOgImageFileAssetId])
  @@map("site_configuration")
}

/// enums and constants
enum CryptoAsset {
  BTC
  ETH
}

enum CryptoNetwork {
  BITCOIN
  ETHEREUM
}

enum CryptoFundingProvider {
  BITPAY
  TRANSAK
}

enum CryptoFundingIntentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  AWAITING_PROVIDER_CONFIRMATION
  FUNDED
  FAILED
  EXPIRED
  CANCELED
}

enum BitPayInvoiceStatus {
  NEW
  PAID
  CONFIRMED
  COMPLETE
  EXPIRED
  INVALID
}

enum CryptoWebhookSource {
  BITPAY
  TRANSAK
}

enum CryptoWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

enum InvestmentOrderStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  REJECTED
  CANCELLED
  PAID
  PENDING_PAYMENT
  PARTIALLY_PAID
}

enum InvestmentType {
  STOCKS
  BONDS
  MUTUAL_FUNDS
  ETFS
  CRYPTO
  REAL_ESTATE
  COMMODITIES
  OTHER
}

enum InvestmentPeriod {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
}

enum InvestmentCatalogStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum KycStatus {
  NOT_STARTED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_FRONT
  ID_BACK
  PROOF_OF_ADDRESS
  DRIVER_LICENSE
  PASSPORT
}

enum FileAssetType {
  AVATAR
  DOCUMENT
  KYC_DOCUMENT
  REPORT
  OTHER
}

enum FileAssetVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}

enum TestimonyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InvestmentTierLevel {
  CORE
  ADVANCED
  ELITE
}

enum FileStorageProvider {
  UPLOADTHING
  S3
  CLOUDINARY
  R2
  LOCAL
}
