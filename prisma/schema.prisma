// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id
  name          String
  email         String
  password      String?
  username      String?
  emailVerified Boolean @default(false)
  image         String?

  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  scheduledDeletionAt DateTime?

  role UserRole @default(USER)

  hasCompletedOnboarding Boolean   @default(false)
  skippedOnboardingAt    DateTime?

  profileAvatarFileAssetId String?
  profileAvatarFileAsset   FileAsset? @relation("UserProfileAvatarAsset", fields: [profileAvatarFileAssetId], references: [id], onDelete: SetNull)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  sessions   Session[]
  accounts   Account[]
  fileAssets FileAsset[] @relation("UploadedByUser")

  investorProfile      InvestorProfile?
  auditLogs            AuditLog[]            @relation("ActorAuditLogs")
  cryptoFundingIntents CryptoFundingIntent[]

  agentConversations  Conversation[]       @relation("ConversationAgent")
  agentProfile        AgentProfile?
  conversationMembers ConversationMember[]
  notifications       Notification[]

  @@unique([email])
  @@index([profileAvatarFileAssetId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordResetAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

/// Central file registry for all uploaded files.
/// Store only metadata here; actual binary lives in S3, UploadThing, Cloudinary, etc.
model FileAsset {
  id String @id @default(cuid())

  fileName     String
  originalName String?

  mimeType       String?
  extension      String?
  sizeBytes      BigInt?
  checksumSha256 String?

  storageKey      String              @unique
  storageBucket   String?
  storageProvider FileStorageProvider
  url             String?

  type       FileAssetType       @default(OTHER)
  visibility FileAssetVisibility @default(PRIVATE)

  uploadedById String?
  uploadedBy   User?   @relation("UploadedByUser", fields: [uploadedById], references: [id], onDelete: SetNull)

  investmentIcons Investment[] @relation("InvestmentIconAsset")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usersAsProfileAvatar     User[]            @relation("UserProfileAvatarAsset")
  investorProfilesAsAvatar InvestorProfile[] @relation("InvestorAvatar")

  siteConfigurationDefaultOgImages SiteConfiguration[] @relation("SiteConfigurationDefaultOgImage")
  siteLogo                         SiteConfiguration?  @relation("SiteConfigurationLogo")
  investmentPlanSeoImages          InvestmentPlan[]    @relation("InvestmentPlanSeoImage")

  testimonies Testimony[]
  management  Management[]

  @@index([uploadedById])
  @@index([type])
  @@index([visibility])
  @@map("file_asset")
}

/// End-user / investor profile
model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber  String?
  dateOfBirth  DateTime?
  age          Int       @default(18)
  country      String?
  state        String?
  city         String?
  addressLine1 String?
  addressLine2 String?

  kycStatus       KycStatus        @default(NOT_STARTED)
  kycVerification KYCVerification?

  avatarFileId String?
  avatarFile   FileAsset? @relation("InvestorAvatar", fields: [avatarFileId], references: [id], onDelete: SetNull)

  investmentAccounts InvestmentAccount[]

  investmentOrders InvestmentOrder[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  withdrawalOrders WithdrawalOrder[]

  @@index([kycStatus])
  @@index([avatarFileId])
  @@map("investor_profile")
}

/// The customer’s actual investment account
model InvestmentAccount {
  id                String @id @default(cuid())
  investorProfileId String
  investmentPlanId  String

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  investmentPlan  InvestmentPlan  @relation(fields: [investmentPlanId], references: [id], onDelete: Restrict)

  pendingWithdrawal Decimal @default(0)

  investmentOrders InvestmentOrder[]
  status           AccountStatus     @default(PENDING)
  balance          Decimal           @default(0) @db.Decimal(18, 2)
  openedAt         DateTime?
  closedAt         DateTime?

  currency String @default("USD")

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  withdrawalOrders WithdrawalOrder[]

  @@unique([investorProfileId, investmentPlanId])
  @@index([investorProfileId])
  @@index([investmentPlanId])
  @@index([status])
  @@map("investment_account")
}

model Investment {
  id   String @id @default(cuid())
  name String
  slug String @unique

  description String?

  type   InvestmentType          @default(CRYPTO)
  status InvestmentCatalogStatus @default(ACTIVE)
  period InvestmentPeriod        @default(LONG_TERM) //remove this later, its not useful anymore

  iconFileAssetId String?
  iconFileAsset   FileAsset? @relation("InvestmentIconAsset", fields: [iconFileAssetId], references: [id], onDelete: SetNull)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  investmentPlans InvestmentPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([sortOrder])
  @@index([iconFileAssetId])
  @@map("investment")
}

model InvestmentPlan {
  id           String @id @default(cuid())
  investmentId String

  name String
  slug String @unique

  description String?

  seoTitle       String?
  seoDescription String?
  seoImageFileId String?
  seoImageFile   FileAsset? @relation("InvestmentPlanSeoImage", fields: [seoImageFileId], references: [id], onDelete: SetNull)

  sortOrder    Int              @default(0)
  durationDays Int              @default(7)
  period       InvestmentPeriod @default(LONG_TERM)

  currency String  @default("USD")
  isActive Boolean @default(true)

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  investmentAccounts InvestmentAccount[]
  investmentOrders   InvestmentOrder[]
  tiers              InvestmentPlanTier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investmentId])
  @@index([period])
  @@index([isActive])
  @@map("investment_plan")
}

model InvestmentPlanTier {
  id               String @id @default(cuid())
  investmentPlanId String

  level InvestmentTierLevel @default(CORE)

  minAmount Decimal @db.Decimal(18, 2)
  maxAmount Decimal @db.Decimal(18, 2)

  roiPercent Decimal @db.Decimal(5, 2)

  isActive Boolean @default(true)

  investmentPlan InvestmentPlan @relation(fields: [investmentPlanId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  investmentOrders InvestmentOrder[]

  @@index([investmentPlanId])
  @@index([level])
  @@map("investment_plan_tier")
}

model InvestmentOrder {
  id                   String @id @default(cuid())
  investorProfileId    String
  investmentPlanId     String
  investmentAccountId  String
  investmentPlanTierId String

  startDate    DateTime?
  maturityDate DateTime?

  expectedReturn Decimal?  @db.Decimal(18, 2)
  completedAt    DateTime?
  isMatured      Boolean   @default(false)

  isWithdrawn Boolean @default(false)

  commissionStatus  CommissionStatus @default(PENDING)
  commissionPercent Decimal          @default(0) @db.Decimal(5, 2)

  accruedProfit Decimal   @default(0) @db.Decimal(18, 2)
  lastAccruedAt DateTime?

  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  status InvestmentOrderStatus @default(PENDING_PAYMENT)

  paymentReference String?
  paidAt           DateTime?
  confirmedAt      DateTime?
  cancelledAt      DateTime?

  cancellationReason String?
  adminNotes         String?

  investmentPlanTier InvestmentPlanTier @relation(fields: [investmentPlanTierId], references: [id])
  investorProfile    InvestorProfile    @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  investmentPlan     InvestmentPlan     @relation(fields: [investmentPlanId], references: [id], onDelete: Restrict)
  investmentAccount  InvestmentAccount  @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  withdrawalOrders   WithdrawalOrder[]
  investmentEarnings InvestmentEarning[]

  @@index([investorProfileId])
  @@index([investmentPlanId])
  @@index([investmentAccountId])
  @@index([status])
  @@index([paidAt])
  @@index([confirmedAt])
  @@index([cancelledAt])
  @@map("investment_order")
}

model InvestmentEarning {
  id String @id @default(cuid())

  investmentOrderId String

  date   DateTime
  amount Decimal  @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  investmentOrder InvestmentOrder @relation(fields: [investmentOrderId], references: [id], onDelete: Cascade)

  @@unique([investmentOrderId, date])
}

/// *
/// * ===========================
/// *        Withdrawal Order
/// * ===========================
model WithdrawalOrder {
  id String @id @default(cuid())

  externalReference String? @unique

  investorProfileId   String
  investmentAccountId String
  investmentOrderId   String?

  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  status WithdrawalStatus @default(PENDING)

  payoutMethod  WithdrawalMethod
  payoutAddress String?

  reference String?

  requestedAt DateTime  @default(now())
  processedAt DateTime?
  completedAt DateTime?
  rejectedAt  DateTime?

  rejectionReason String?
  adminNotes      String?

  investorProfile   InvestorProfile   @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  investmentAccount InvestmentAccount @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)
  investmentOrder   InvestmentOrder?  @relation(fields: [investmentOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorProfileId])
  @@index([investmentAccountId])
  @@index([investmentOrderId])
  @@index([status])
  @@map("withdrawal_order")
}

/// *
/// * ===========================
/// * 
/// * ===========================
model CronJob {
  id String @id @default(cuid())

  key String @unique

  lastRunAt DateTime?
  nextRunAt DateTime?
  isRunning Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CronLock {
  name     String   @id
  lockedAt DateTime
}

/// *
/// * ===========================
/// *   KYC & DOCUMENT VERIFICATION
/// * ===========================
model KYCVerification {
  id String @id @default(cuid())

  investorProfileId String          @unique
  investorProfile   InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)

  provider String @default("didit")

  providerSessionId String?
  vendorData        String?

  status KycStatus @default(PENDING_REVIEW)

  faceMatchScore Float?
  livenessPassed Boolean?

  failureReason String?

  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// *
/// * ===========================
/// *   AUDIT LOGS
/// * ===========================
model AuditLog {
  id          String  @id @default(cuid())
  actorUserId String?
  actorUser   User?   @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  action      String
  entityType  String
  entityId    String?
  description String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

/// *
/// * ===========================
/// *    TESTIMONIES
/// * ===========================
model Testimony {
  id          String          @id @default(cuid())
  fullName    String
  roleOrTitle String?         @default("CLIENT")
  message     String
  rating      Int?
  isFeatured  Boolean         @default(false)
  status      TestimonyStatus @default(DRAFT)

  avatarFileId String?
  avatarFile   FileAsset? @relation(fields: [avatarFileId], references: [id], onDelete: SetNull)

  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([avatarFileId])
  @@map("testimony")
}

/// *
/// * ===========================
/// *     MANAGEMENT
/// * ===========================
model Management {
  id String @id @default(cuid())

  name  String
  title String?
  role  String?

  email String?
  phone String?
  bio   String?

  photoFileId String?
  photoFile   FileAsset? @relation(fields: [photoFileId], references: [id], onDelete: SetNull)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  @@index([photoFileId])
  @@map("management")
}

/// *
/// * ===========================
/// *     PLATFORM WALLETS & CRYPTO FUNDING
/// * ===========================
model PlatformWallet {
  id        String        @id @default(cuid())
  label     String
  asset     CryptoAsset
  network   CryptoNetwork
  address   String
  isActive  Boolean       @default(true)
  isDefault Boolean       @default(false)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  fundingIntents CryptoFundingIntent[]

  @@unique([network, address])
  @@index([asset, network, isActive])
  @@index([isDefault, isActive])
}

model CryptoFundingIntent {
  id       String                @id @default(cuid())
  userId   String
  provider CryptoFundingProvider
  asset    CryptoAsset
  network  CryptoNetwork

  fiatCurrency String  @default("USD")
  fiatAmount   Decimal @db.Decimal(18, 2)

  expectedCryptoAmount Decimal? @db.Decimal(36, 18)
  receivedCryptoAmount Decimal? @db.Decimal(36, 18)

  status CryptoFundingIntentStatus @default(PENDING)

  platformWalletId         String?
  destinationWalletAddress String
  destinationWalletLabel   String?

  providerSessionId  String?
  providerExternalId String?
  providerReference  String?

  partnerCustomerId String?
  redirectUrl       String?

  expiresAt  DateTime?
  fundedAt   DateTime?
  failedAt   DateTime?
  canceledAt DateTime?

  failureCode    String?
  failureMessage String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformWallet PlatformWallet? @relation(fields: [platformWalletId], references: [id], onDelete: SetNull)

  bitpayInvoicePayment BitPayInvoicePayment?
  webhookEvents        CryptoWebhookEvent[]

  @@index([userId, status])
  @@index([provider, status])
  @@index([asset, network])
  @@index([providerSessionId])
  @@index([providerExternalId])
  @@index([createdAt])
}

model BitPayInvoicePayment {
  id              String @id @default(cuid())
  fundingIntentId String @unique

  bitpayInvoiceId String              @unique
  bitpayOrderId   String?
  bitpayToken     String?
  status          BitPayInvoiceStatus @default(NEW)

  price    Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  cryptoAsset   CryptoAsset?
  cryptoNetwork CryptoNetwork?
  amountPaid    Decimal?       @db.Decimal(36, 18)
  amountDue     Decimal?       @db.Decimal(36, 18)
  exchangeRate  Decimal?       @db.Decimal(36, 18)

  invoiceUrl String?
  posData    String?

  paidAt      DateTime?
  confirmedAt DateTime?
  completedAt DateTime?
  expiredAt   DateTime?
  invalidAt   DateTime?

  rawInvoiceSnapshot Json?
  rawStatusPayload   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundingIntent CryptoFundingIntent @relation(fields: [fundingIntentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model CryptoWebhookEvent {
  id               String                        @id @default(cuid())
  source           CryptoWebhookSource
  eventType        String
  processingStatus CryptoWebhookProcessingStatus @default(RECEIVED)

  fundingIntentId  String?
  providerEventId  String?
  providerObjectId String?

  idempotencyKey String? @unique
  signature      String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  failedAt    DateTime?

  errorMessage String?
  payload      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fundingIntent CryptoFundingIntent? @relation(fields: [fundingIntentId], references: [id], onDelete: SetNull)

  @@index([source, eventType])
  @@index([processingStatus])
  @@index([providerEventId])
  @@index([providerObjectId])
  @@index([receivedAt])
}

/// *
/// * ===========================
/// * MESSAGE SYSTEM & NOTIFICATIONS
/// * ===========================
model Conversation {
  id                  String  @id @default(cuid())
  investmentAccountId String?

  type   ConversationType
  status ConversationStatus @default(OPEN)

  subject       String?
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String?
  agent   User?   @relation("ConversationAgent", fields: [agentId], references: [id])

  priority ConversationPriority @default(NORMAL)

  members  ConversationMember[]
  messages Message[]

  @@index([lastMessageAt])
  @@index([type, status])
}

model AgentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String @id @default(cuid())
  conversationId String

  senderId   String?
  senderType SenderType

  content String

  conversation Conversation @relation(fields: [conversationId], references: [id])

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  @@index([conversationId, createdAt])
}

model ConversationMember {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  role ConversationRole @default(USER)

  joinedAt DateTime @default(now())

  unreadCount Int @default(0)

  lastReadAt DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  title   String
  message String
  read    Boolean @default(false)

  link String?
  type String?

  key String? @unique

  metadata Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// *
/// * ===========================
/// *   SITE CONFIGURATION
/// * ===========================
model SiteConfiguration {
  id String @id @default("default")

  siteName     String
  supportEmail String?
  supportPhone String?

  siteDescription String?
  siteTagline     String?

  siteLogoFileAssetId String?    @unique
  siteLogoFileAsset   FileAsset? @relation("SiteConfigurationLogo", fields: [siteLogoFileAssetId], references: [id], onDelete: SetNull)

  seoTitle       String?
  seoDescription String?

  locale   String?  @default("en_US")
  keywords String[] @default([])

  defaultTwitterHandle String?
  facebookUrl          String?
  instagramUrl         String?

  defaultOgImageFileAssetId String?
  defaultOgImageFileAsset   FileAsset? @relation("SiteConfigurationDefaultOgImage", fields: [defaultOgImageFileAssetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([defaultOgImageFileAssetId])
  @@map("site_configuration")
}

/// enums and constants
enum CryptoAsset {
  BTC
  ETH
}

enum CryptoNetwork {
  BITCOIN
  ETHEREUM
}

enum CryptoFundingProvider {
  BITPAY
  TRANSAK
}

enum CryptoFundingIntentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  AWAITING_PROVIDER_CONFIRMATION
  FUNDED
  FAILED
  EXPIRED
  CANCELED
}

enum BitPayInvoiceStatus {
  NEW
  PAID
  CONFIRMED
  COMPLETE
  EXPIRED
  INVALID
}

enum CryptoWebhookSource {
  BITPAY
  TRANSAK
}

enum CryptoWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

enum InvestmentOrderStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  REJECTED
  CANCELLED
  PAID
  PENDING_PAYMENT
  PARTIALLY_PAID
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
  PARTIALLY_PAID
  VOID
}

enum InvestmentType {
  STOCKS
  BONDS
  MUTUAL_FUNDS
  ETFS
  CRYPTO
  REAL_ESTATE
  COMMODITIES
  OTHER
}

enum InvestmentPeriod {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
}

enum InvestmentCatalogStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum WithdrawalMethod {
  BANK_TRANSFER
  CRYPTO_WALLET
}

enum KycStatus {
  NOT_STARTED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_FRONT
  ID_BACK
  PROOF_OF_ADDRESS
  DRIVER_LICENSE
  PASSPORT
  SELFIE
}

enum FileAssetType {
  AVATAR
  DOCUMENT
  KYC_DOCUMENT
  REPORT
  OTHER
}

enum FileAssetVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}

enum TestimonyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InvestmentTierLevel {
  CORE
  ADVANCED
  ELITE
}

enum FileStorageProvider {
  UPLOADTHING
  S3
  CLOUDINARY
  R2
  LOCAL
}

enum ConversationType {
  SUPPORT
  SYSTEM
  ACCOUNT_ISSUES
  INVESTMENT_INQUIRIES
}

enum ConversationStatus {
  OPEN
  RESOLVED
  CLOSED
  ARCHIVED
  WAITING
  CANCELLED
  REJECTED
  BLOCKED
  DELETED
}

enum SenderType {
  USER
  SUPPORT
  SYSTEM
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ConversationRole {
  USER
  SUPPORT
  ADMIN
  SYSTEM
}
